{
  "name": "firstpip-workroom-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "퍼스트핍 워크룸 대시보드 — src/app.jsx 를 esbuild로 app.js 로 트랜스파일. 브라우저 인라인 Babel 제거.",
  "scripts": {
    "build": "esbuild src/app.jsx --bundle --format=iife --outfile=app.js --jsx=transform --minify --target=es2020 --legal-comments=none",
    "watch": "esbuild src/app.jsx --bundle --format=iife --outfile=app.js --jsx=transform --target=es2020 --sourcemap --watch"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
