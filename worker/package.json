{
  "name": "portfolio-showcase-worker",
  "private": true,
  "version": "0.0.1",
  "description": "Local worker for demo generator. Watches Supabase for status transitions and runs Claude (via Max subscription) + GitHub deploys.",
  "type": "module",
  "scripts": {
    "start": "tsx index.ts",
    "dev": "tsx watch index.ts",
    "test:claude": "tsx test-claude.ts",
    "test:supabase": "tsx test-supabase.ts",
    "test:save-spec": "tsx test-save-spec.ts",
    "test:save-spec-structured": "tsx test-save-spec-structured.ts",
    "test:approve-flow": "tsx test-approve-flow.ts",
    "test:extract-spec": "tsx test-extract-spec.ts",
    "test:extract-spec-prompt": "tsx test-extract-spec-prompt.ts",
    "test:auth-fail": "tsx test-auth-fail.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
